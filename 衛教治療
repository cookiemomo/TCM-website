<script>
(function(){
  var cur = null;
  var ids = ['sx','cz','bt','yx','hg'];
  window.acuPill = function(id, btn) {
    ids.forEach(function(k){
      var p = document.getElementById('ai-'+k);
      if(p) p.style.display = 'none';
    });
    document.querySelectorAll('.acu-pill').forEach(function(b){
      b.style.background = '';
      b.style.color = '';
      b.style.borderColor = '';
    });
    if(cur === id){ cur = null; return; }
    var panel = document.getElementById('ai-'+id);
    if(panel){
      panel.style.display = 'block';
      setTimeout(function(){ panel.scrollIntoView({behavior:'smooth', block:'nearest'}); }, 60);
    }
    var isOrange = (id === 'yx');
    btn.style.background = isOrange ? '#E8762B' : '#2E7D6F';
    btn.style.color = '#fff';
    btn.style.borderColor = isOrange ? '#E8762B' : '#2E7D6F';
    cur = id;
  };
})();
</script>

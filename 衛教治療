<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>中醫治療過敏性鼻炎</title>

<style>
  :root {
    --orange: #E8762B;
    --orange-light: #FFF0E4;
    --orange-mid: #F4A45C;
    --warm-cream: #FEF8F0;
    --warm-white: #FFFCF7;
    --brown: #7A4828;
    --brown-light: #F5EDE3;
    --brown-mid: #C49070;
    --teal: #2E7D6F;
    --teal-light: #E3F5F1;
    --teal-mid: #6BB8AC;
    --ink: #2C1A0E;
    --ink-soft: #5C3D25;
    --muted: #9E7A60;
    --yellow: #F5C842;
    --yellow-light: #FFFAE8;
    --border: rgba(122, 72, 40, 0.10);
    --shadow: 0 8px 32px rgba(122, 72, 40, 0.10);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--warm-cream);
    color: var(--ink);
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', 'Heiti TC', sans-serif;
    font-weight: 300;
    line-height: 1.8;
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #FDE8C8 0%, #F9D4A2 40%, #F4C07A 100%);
    min-height: 560px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 0;
    position: relative;
    overflow: hidden;
    padding: 0;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 60% 50%, rgba(255,255,255,0.25) 0%, transparent 70%);
  }
  .hero-left {
    padding: 72px 48px 72px 64px;
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(230,120,43,0.3);
    color: var(--brown);
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    padding: 7px 16px;
    border-radius: 40px;
    margin-bottom: 24px;
  }
  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--orange);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .hero h1 {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: clamp(30px, 4.5vw, 50px);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    letter-spacing: 0.03em;
    margin-bottom: 20px;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--orange);
  }
  .hero-desc {
    font-size: 15px;
    color: var(--ink-soft);
    max-width: 360px;
    line-height: 1.9;
    margin-bottom: 32px;
  }
  .hero-symptoms {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .s-tag {
    background: rgba(255,255,255,0.65);
    border: 1px solid rgba(230,120,43,0.22);
    color: var(--brown);
    font-size: 13px;
    padding: 7px 16px;
    border-radius: 40px;
    backdrop-filter: blur(4px);
  }
  .hero-right {
    position: relative;
    height: 100%;
    min-height: 560px;
    overflow: hidden;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .hero-img-fade {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 100%;
    background: linear-gradient(to right, #F9D4A2 0%, transparent 35%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── CONCEPT ── */
  .concept-section {
    background: var(--warm-white);
    padding: 80px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .container { max-width: 920px; margin: 0 auto; padding: 0 28px; }
  .sec-label {
    display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
  }
  .sec-label::before {
    content: ''; display: block;
    width: 28px; height: 2px;
    background: var(--orange); flex-shrink: 0;
  }
  .sec-label span {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--orange);
  }
  .sec-heading {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 30px; font-weight: 500;
    color: var(--ink); margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .sec-sub {
    font-size: 15px; color: var(--muted);
    margin-bottom: 40px; max-width: 480px; line-height: 1.9;
  }
  .concept-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
  }
  .c-card {
    background: var(--warm-cream);
    border: 1px solid var(--border);
    border-radius: 20px; padding: 28px 28px 28px 32px;
    position: relative; overflow: hidden;
  }
  .c-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; width: 4px; height: 100%;
    background: var(--teal); border-radius: 4px 0 0 4px;
  }
  .c-card.orange::before { background: var(--orange); }
  .c-card h3 {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 17px; font-weight: 500;
    color: var(--ink); margin-bottom: 10px;
  }
  .c-card p {
    font-size: 14px; color: var(--ink-soft); line-height: 1.9;
  }

  /* ── TREATMENTS ── */
  .treat-section { padding: 80px 0; background: var(--warm-cream); }
  .treat-list { display: flex; flex-direction: column; gap: 24px; margin-top: 8px; }
  .t-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 24px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 100px 1fr;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .t-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-3px);
  }
  .t-side {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; padding: 28px 12px;
  }
  .t-side.s1 { background: #2E7D6F; }
  .t-side.s2 { background: #C4702A; }
  .t-side.s3 { background: #8B5A2E; }
  .t-side.s4 { background: #3A6960; }
  .t-side.s5 { background: #4A3520; }
  .t-side.s6 { background: #6B4B2F; }
  .t-num { font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif; font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.1em; }
  .t-big { font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif; font-size: 36px; font-weight: 300; color: rgba(255,255,255,0.92); line-height: 1; }
  .t-icon {
    width: 28px; height: 28px;
    background: rgba(255,255,255,0.15);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .t-icon svg { width: 14px; height: 14px; fill: none; stroke: rgba(255,255,255,0.85); stroke-width: 1.5; stroke-linecap: round; }
  .t-body { padding: 28px 32px; }
  .t-title {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 19px; font-weight: 500; color: var(--ink);
    margin-bottom: 12px;
  }
  .t-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.9; margin-bottom: 18px; }
  .t-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .t-tag {
    font-size: 12px; padding: 5px 13px;
    border-radius: 40px; border: 1px solid;
  }
  .t-tag.g {
    background: var(--teal-light); color: #1D5248;
    border-color: rgba(46,125,111,0.2);
  }
  .t-tag.o {
    background: var(--orange-light); color: #8B4A18;
    border-color: rgba(230,120,43,0.2);
  }
  .t-tag.b {
    background: var(--brown-light); color: var(--brown);
    border-color: rgba(122,72,40,0.18);
  }
  .t-tag.y {
    background: var(--yellow-light); color: #7A6010;
    border-color: rgba(200,160,30,0.2);
  }
  .acupoints {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(110px,1fr));
    gap: 10px; margin-top: 16px;
  }
  .acu-item {
    background: var(--warm-cream);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 14px;
    text-align: center;
  }
  .acu-name {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 15px; font-weight: 500; color: var(--ink);
    display: block; margin-bottom: 3px;
  }
  .acu-loc { font-size: 11px; color: var(--muted); }

  /* ── DAILY ── */
  .daily-section {
    background: linear-gradient(160deg, #2C1A0E 0%, #3D2510 60%, #1E3D35 100%);
    padding: 80px 0;
  }
  .daily-section .sec-heading { color: #FEF8F0; }
  .daily-section .sec-sub { color: rgba(254,248,240,0.6); }
  .daily-section .sec-label::before { background: var(--orange-mid); }
  .daily-section .sec-label span { color: var(--orange-mid); }
  .daily-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
    gap: 16px;
  }
  .d-item {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px; padding: 24px;
    transition: background 0.3s;
  }
  .d-item:hover { background: rgba(255,255,255,0.10); }
  .d-icon {
    width: 38px; height: 38px;
    background: rgba(244,164,92,0.2);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
  }
  .d-icon svg { width: 18px; height: 18px; fill: none; stroke: var(--orange-mid); stroke-width: 1.5; stroke-linecap: round; }
  .d-item h4 {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 15px; font-weight: 500; color: #FEF8F0;
    margin-bottom: 8px;
  }
  .d-item p { font-size: 13px; color: rgba(254,248,240,0.6); line-height: 1.8; }

  /* ── SUMMARY ── */
  .summary-section {
    background: var(--warm-white);
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }
  .summary-inner {
    background: linear-gradient(140deg, #FFF0E4 0%, #F5EDE3 100%);
    border: 1px solid rgba(230,120,43,0.12);
    border-radius: 28px;
    padding: 56px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .summary-inner::after {
    content: '鼽';
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 220px; font-weight: 600;
    color: rgba(230,120,43,0.05);
    position: absolute; bottom: -40px; right: -20px;
    line-height: 1; pointer-events: none;
  }
  .summary-inner h2 {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 26px; font-weight: 500; color: var(--ink);
    margin-bottom: 18px;
  }
  .summary-inner p {
    font-size: 15px; color: var(--ink-soft);
    max-width: 560px; margin: 0 auto; line-height: 2;
  }
  .sum-pills {
    display: flex; justify-content: center;
    flex-wrap: wrap; gap: 10px; margin-top: 28px;
  }
  .sum-pill {
    font-family: 'Microsoft JhengHei', '微軟正黑體', 'PingFang TC', sans-serif;
    font-size: 13px; padding: 8px 20px;
    border-radius: 40px;
    background: rgba(255,255,255,0.7);
    color: var(--brown);
    border: 1px solid rgba(122,72,40,0.15);
  }

  footer {
    background: var(--ink);
    color: rgba(254,248,240,0.4);
    text-align: center;
    padding: 24px; font-size: 12px;
    letter-spacing: 0.05em;
  }

  /* animations */
  .fade-up {
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 700px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: 260px auto;
      min-height: unset;
    }
    .hero-right {
      grid-row: 1;
      min-height: 260px;
      height: 260px;
    }
    .hero-img-fade {
      background: linear-gradient(to bottom, transparent 50%, #F9D4A2 100%);
    }
    .hero-left {
      grid-row: 2;
      padding: 28px 20px 40px;
    }
    .hero h1 { font-size: 26px; }
    .hero-desc { font-size: 14px; max-width: 100%; }
    .s-tag { font-size: 12px; padding: 6px 13px; }
    .container { padding: 0 16px; }
    .concept-section, .treat-section, .summary-section { padding: 52px 0; }
    .daily-section { padding: 52px 0; }
    .sec-heading { font-size: 22px; }
    .sec-sub { font-size: 14px; margin-bottom: 28px; }
    .concept-grid { grid-template-columns: 1fr; gap: 14px; }
    .c-card { padding: 22px 22px 22px 26px; }
    .treat-list { gap: 16px; }
    .t-card { grid-template-columns: 64px 1fr; border-radius: 18px; }
    .t-side { padding: 20px 8px; }
    .t-num { font-size: 10px; }
    .t-big { font-size: 28px; }
    .t-icon { width: 24px; height: 24px; border-radius: 6px; }
    .t-icon svg { width: 12px; height: 12px; }
    .t-body { padding: 18px 16px; }
    .t-title { font-size: 17px; margin-bottom: 8px; }
    .t-desc { font-size: 13px; margin-bottom: 14px; }
    .t-tag { font-size: 11px; padding: 4px 11px; }
    .acupoints { grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .acu-item { padding: 10px 8px; }
    .acu-name { font-size: 14px; }
    .acu-loc { font-size: 10px; }
    .daily-grid { grid-template-columns: 1fr; gap: 12px; }
    .d-item { padding: 20px; }
    .summary-inner { padding: 36px 20px; }
    .summary-inner h2 { font-size: 20px; }
    .summary-inner p { font-size: 14px; }
    .sum-pill { font-size: 12px; padding: 7px 16px; }
    .summary-inner::after { font-size: 140px; }
  }
  @media (max-width: 380px) {
    .hero h1 { font-size: 23px; }
    .acupoints { grid-template-columns: repeat(2, 1fr); }
  }

  

  /* ── SCROLL ANIMATIONS ── */
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-32px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(32px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes floatUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes popIn {
    0%   { opacity: 0; transform: scale(0.85); }
    70%  { transform: scale(1.04); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }

  .anim-left  { opacity: 0; }
  .anim-right { opacity: 0; }
  .anim-up    { opacity: 0; }
  .anim-pop   { opacity: 0; }

  .anim-left.animated  { animation: slideInLeft  0.7s ease forwards; }
  .anim-right.animated { animation: slideInRight 0.7s ease forwards; }
  .anim-up.animated    { animation: floatUp      0.65s ease forwards; }
  .anim-pop.animated   { animation: popIn        0.6s cubic-bezier(.22,.68,0,1.2) forwards; }

  /* hero floating badge pulse */
  .hero-badge { animation: pulse-badge 3s ease-in-out infinite; }
  @keyframes pulse-badge {
    0%,100% { box-shadow: 0 0 0 0 rgba(230,120,43,0); }
    50%     { box-shadow: 0 0 0 6px rgba(230,120,43,0.15); }
  }

  /* symptom tags stagger */
  .hero-symptoms .s-tag { opacity:0; animation: floatUp 0.5s ease forwards; }
  .hero-symptoms .s-tag:nth-child(1) { animation-delay: 0.1s; }
  .hero-symptoms .s-tag:nth-child(2) { animation-delay: 0.2s; }
  .hero-symptoms .s-tag:nth-child(3) { animation-delay: 0.3s; }
  .hero-symptoms .s-tag:nth-child(4) { animation-delay: 0.4s; }


  /* ── LIGHTBOX ── */
  .lb-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(20,10,5,0.85);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    cursor: zoom-out;
  }
  .lb-overlay.open { display: flex; animation: lbFadeIn 0.25s ease; }
  .lb-overlay img {
    max-width: 90vw; max-height: 88vh;
    border-radius: 20px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6);
    animation: lbZoomIn 0.3s cubic-bezier(.22,.68,0,1.15);
  }
  .lb-close {
    position: fixed; top: 20px; right: 24px;
    color: #fff; font-size: 32px; cursor: pointer;
    background: rgba(255,255,255,0.15);
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    line-height: 1; border: none;
    transition: background 0.2s;
  }
  .lb-close:hover { background: rgba(255,255,255,0.28); }
  @keyframes lbFadeIn  { from { opacity:0; } to { opacity:1; } }
  @keyframes lbZoomIn  { from { opacity:0; transform:scale(0.82); } to { opacity:1; transform:scale(1); } }

  /* ── THUMBNAIL STYLE ── */
  .t-img-wrap {
    margin-top: 16px;
    position: relative;
    cursor: zoom-in;
  }
  .t-img-wrap img {
    width: 100%;
    max-height: 200px;
    object-fit: cover;
    display: block;
    border-radius: 14px;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .t-card:hover .t-img-wrap img {
    transform: scale(1.03);
    box-shadow: 0 8px 28px rgba(60,30,10,0.18);
  }
  .t-img-zoom-hint {
    position: absolute; bottom: 8px; right: 10px;
    background: rgba(0,0,0,0.45);
    color: #fff; font-size: 11px;
    padding: 3px 9px; border-radius: 20px;
    pointer-events: none; letter-spacing: 0.05em;
  }


    .waizhi-icon {
    width: 38px; height: 38px; flex-shrink: 0;
    background: var(--orange-light);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: var(--orange);
  }
  .waizhi-icon svg { width: 20px; height: 20px; }
  .waizhi-label {
    font-size: 13px; font-weight: 500;
    color: var(--orange); letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .waizhi-text {
    font-size: 14px; color: var(--ink-soft);
    line-height: 1.9; margin: 0;
  }
  @media (max-width: 700px) {


  /* ── INLINE TERM TOOLTIP ── */
  .term-btn {
    display: inline;
    color: var(--teal);
    font-weight: 500;
    border-bottom: 2px dashed var(--teal-mid);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    padding: 0;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }
  .term-btn:hover { color: var(--teal); border-bottom-style: solid; }

  .term-popup {
    display: none;
    background: linear-gradient(135deg, #E3F5F1 0%, #D4EEE9 100%);
    border: 1px solid rgba(46,125,111,0.22);
    border-left: 4px solid var(--teal);
    border-radius: 14px;
    padding: 14px 18px;
    margin-top: 12px;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.85;
    position: relative;
    animation: popIn 0.3s cubic-bezier(.22,.68,0,1.2);
  }
  .term-popup.open { display: block; }
  .term-popup::before {
    content: '';
    position: absolute;
    top: -8px; left: 24px;
    width: 14px; height: 14px;
    background: #E3F5F1;
    border-top: 1px solid rgba(46,125,111,0.22);
    border-left: 1px solid rgba(46,125,111,0.22);
    transform: rotate(45deg);
    border-radius: 2px;
  }
  .term-popup-label {
    font-size: 11px; font-weight: 500;
    color: var(--teal); letter-spacing: 0.12em;
    margin-bottom: 6px; display: block;
  }
  .term-popup-close {
    position: absolute; top: 10px; right: 12px;
    font-size: 13px; color: var(--teal-mid);
    cursor: pointer; background: none; border: none;
    padding: 2px 6px; border-radius: 6px;
    transition: background 0.2s;
  }
  .term-popup-close:hover { background: rgba(46,125,111,0.12); }


  


  
  

  
  /* ── ACU PILL SELECTOR ── */
  .acu-pills { display: flex; flex-wrap: wrap; gap: 8px; margin: 14px 0; }
